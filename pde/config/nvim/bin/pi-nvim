#!/usr/bin/env bash
# Launch pi with all configured extensions EXCEPT pi-pretty.
# pi-pretty has a stale-ctx bug on session reload that we want to avoid in nvim.
set -euo pipefail

SETTINGS="${HOME}/.pi/agent/settings.json"
NPM_ROOT="$(npm root -g)"
EXCLUDE="npm:@heyhuynhgiabuu/pi-pretty"

if [[ ! -r "$SETTINGS" ]]; then
    exec pi "$@"
fi

# Build --extension <path> pairs for every package except the excluded one.
args=(--no-extensions)
while IFS= read -r pkg; do
    [[ -z "$pkg" || "$pkg" == "$EXCLUDE" ]] && continue
    case "$pkg" in
        npm:*) path="${NPM_ROOT}/${pkg#npm:}" ;;
        *) continue ;;
    esac
    [[ -d "$path" ]] && args+=(-e "$path")
done < <(jq -r '.packages[]? // empty' "$SETTINGS")

exec pi "${args[@]}" "$@"
