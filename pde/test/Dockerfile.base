# Pre-built base image for PDE testing
# Build: docker build -t pde-base:22.04 --build-arg UBUNTU_VERSION=22.04 -f test/Dockerfile.base .
ARG UBUNTU_VERSION=24.04
FROM ubuntu:${UBUNTU_VERSION}

ENV DEBIAN_FRONTEND=noninteractive

# Core dependencies + tmux build deps + CLI tools
RUN apt-get update && apt-get install -y \
    sudo git curl zsh \
    build-essential libevent-dev libncurses-dev bison \
    fd-find fzf ripgrep bat jq htop unzip \
    && rm -rf /var/lib/apt/lists/*

# Pre-build tmux 3.6a
ARG TMUX_VERSION=3.6a
RUN curl -fsSL "https://github.com/tmux/tmux/releases/download/${TMUX_VERSION}/tmux-${TMUX_VERSION}.tar.gz" | tar xz \
    && cd tmux-${TMUX_VERSION} \
    && ./configure --prefix=/usr/local \
    && make -j$(nproc) \
    && make install \
    && cd / && rm -rf /tmux-${TMUX_VERSION}

# Create test user
RUN useradd -m -s /bin/bash testuser \
    && echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER testuser
WORKDIR /home/testuser
